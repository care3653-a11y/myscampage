# Copy this file to ".env" and fill in real values, or export these in your shell.
# Never commit your real .env.

# Flask session signing key. Generate one with:
#   python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=

# Database. Defaults to a local SQLite file if unset.
# DATABASE_URL=sqlite:///myscamshield.db
# DATABASE_URL=postgresql+psycopg2://user:pass@host:5432/dbname

# Admin (volunteer) sign-in. If ADMIN_PASSWORD is unset, the app prints a
# temporary random password to the console on startup.
ADMIN_USERNAME=admin
ADMIN_PASSWORD=

# Set to 1 only for local debugging. Never in production.
FLASK_DEBUG=0
